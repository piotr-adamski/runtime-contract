{
  "$defs": {
    "AnalysisCompleteness": {
      "enum": [
        "complete",
        "partial",
        "failed"
      ],
      "title": "AnalysisCompleteness",
      "type": "string"
    },
    "AnalysisDiagnostic": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "$ref": "#/$defs/DiagnosticCode"
        },
        "id": {
          "default": "",
          "title": "Id",
          "type": "string"
        },
        "parameters": {
          "default": [],
          "items": {
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ],
            "type": "array"
          },
          "title": "Parameters",
          "type": "array"
        },
        "primary_location": {
          "$ref": "#/$defs/SourceLocation"
        },
        "related_locations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceLocation"
          },
          "title": "Related Locations",
          "type": "array"
        },
        "rule_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/RuleId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        }
      },
      "required": [
        "code",
        "severity",
        "primary_location"
      ],
      "title": "AnalysisDiagnostic",
      "type": "object"
    },
    "Confidence": {
      "enum": [
        "exact",
        "inferred"
      ],
      "title": "Confidence",
      "type": "string"
    },
    "ConfigKey": {
      "additionalProperties": false,
      "properties": {
        "allow_literal": {
          "title": "Allow Literal",
          "type": "boolean"
        },
        "component": {
          "title": "Component",
          "type": "string"
        },
        "id": {
          "default": "",
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "secret": {
          "title": "Secret",
          "type": "boolean"
        },
        "secret_source": {
          "$ref": "#/$defs/SecretSource"
        },
        "sensitivity_confidence": {
          "$ref": "#/$defs/SensitivityConfidence",
          "default": "none"
        },
        "sensitivity_reason": {
          "$ref": "#/$defs/SensitivityReason",
          "default": "no_match"
        },
        "severity_override": {
          "anyOf": [
            {
              "$ref": "#/$defs/Severity"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name",
        "component",
        "secret",
        "secret_source",
        "allow_literal"
      ],
      "title": "ConfigKey",
      "type": "object"
    },
    "Consumer": {
      "additionalProperties": false,
      "properties": {
        "access_kind": {
          "$ref": "#/$defs/ConsumerAccessKind"
        },
        "component": {
          "title": "Component",
          "type": "string"
        },
        "config_key_id": {
          "title": "Config Key Id",
          "type": "string"
        },
        "has_literal_fallback": {
          "title": "Has Literal Fallback",
          "type": "boolean"
        },
        "id": {
          "default": "",
          "title": "Id",
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/SourceLocation"
        },
        "phase": {
          "$ref": "#/$defs/Phase"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "requirement_source": {
          "$ref": "#/$defs/RequirementSource"
        }
      },
      "required": [
        "config_key_id",
        "component",
        "phase",
        "required",
        "requirement_source",
        "access_kind",
        "location",
        "has_literal_fallback"
      ],
      "title": "Consumer",
      "type": "object"
    },
    "ConsumerAccessKind": {
      "enum": [
        "python_os_environ",
        "python_os_environ_get",
        "python_os_getenv",
        "pydantic_settings",
        "node_process_env",
        "vite_import_meta_env"
      ],
      "title": "ConsumerAccessKind",
      "type": "string"
    },
    "DiagnosticCode": {
      "enum": [
        "invalid_encoding",
        "syntax_error",
        "dynamic_name",
        "unsupported_construct",
        "partial_analysis",
        "analyzer_not_registered",
        "analyzer_contract",
        "filesystem_mutation",
        "normalization_error",
        "read_error",
        "safety_limit",
        "unsupported_k8s_resource",
        "unused_classification_rule"
      ],
      "title": "DiagnosticCode",
      "type": "string"
    },
    "Environment": {
      "additionalProperties": false,
      "properties": {
        "component": {
          "title": "Component",
          "type": "string"
        },
        "id": {
          "default": "",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/EnvironmentKind"
        },
        "profile": {
          "$ref": "#/$defs/Profile"
        },
        "target": {
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "component",
        "target",
        "kind",
        "profile"
      ],
      "title": "Environment",
      "type": "object"
    },
    "EnvironmentKind": {
      "enum": [
        "implicit",
        "compose_service",
        "kubernetes_workload"
      ],
      "title": "EnvironmentKind",
      "type": "string"
    },
    "EvidenceKind": {
      "enum": [
        "explicit_key",
        "resolved_bulk",
        "unresolved_bulk"
      ],
      "title": "EvidenceKind",
      "type": "string"
    },
    "FactKind": {
      "enum": [
        "config_key",
        "environment",
        "consumer",
        "provider"
      ],
      "title": "FactKind",
      "type": "string"
    },
    "FactObservation": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "$ref": "#/$defs/Confidence"
        },
        "fact": {
          "anyOf": [
            {
              "$ref": "#/$defs/ConfigKey"
            },
            {
              "$ref": "#/$defs/Environment"
            },
            {
              "$ref": "#/$defs/Consumer"
            },
            {
              "$ref": "#/$defs/Provider"
            }
          ],
          "title": "Fact"
        },
        "fact_kind": {
          "$ref": "#/$defs/FactKind"
        }
      },
      "required": [
        "fact_kind",
        "confidence",
        "fact"
      ],
      "title": "FactObservation",
      "type": "object"
    },
    "Phase": {
      "enum": [
        "build",
        "runtime",
        "not_applicable"
      ],
      "title": "Phase",
      "type": "string"
    },
    "Profile": {
      "enum": [
        "default",
        "dev",
        "staging",
        "prod"
      ],
      "title": "Profile",
      "type": "string"
    },
    "Provider": {
      "additionalProperties": false,
      "properties": {
        "component": {
          "title": "Component",
          "type": "string"
        },
        "config_key_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Config Key Id"
        },
        "environment_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Environment Id"
        },
        "evidence_kind": {
          "$ref": "#/$defs/EvidenceKind"
        },
        "id": {
          "default": "",
          "title": "Id",
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/SourceLocation"
        },
        "mechanism": {
          "$ref": "#/$defs/ProviderMechanism"
        },
        "phase": {
          "$ref": "#/$defs/Phase"
        },
        "role": {
          "$ref": "#/$defs/ProviderRole"
        }
      },
      "required": [
        "component",
        "role",
        "phase",
        "mechanism",
        "evidence_kind",
        "location"
      ],
      "title": "Provider",
      "type": "object"
    },
    "ProviderMechanism": {
      "enum": [
        "env_example",
        "dockerfile_arg",
        "dockerfile_env",
        "compose_build_args",
        "compose_environment",
        "compose_env_file",
        "kubernetes_env",
        "kubernetes_env_from"
      ],
      "title": "ProviderMechanism",
      "type": "string"
    },
    "ProviderRole": {
      "enum": [
        "declaration",
        "delivery"
      ],
      "title": "ProviderRole",
      "type": "string"
    },
    "RequirementSource": {
      "enum": [
        "detected_default",
        "literal_fallback",
        "config_override"
      ],
      "title": "RequirementSource",
      "type": "string"
    },
    "RuleId": {
      "description": "Identifiers shared by findings, configuration, and JSON Schema.",
      "enum": [
        "RTC001",
        "RTC002",
        "RTC003",
        "RTC004",
        "RTC005",
        "RTC006",
        "RTC007",
        "RTC008",
        "RTC009",
        "RTC010",
        "RTC011",
        "RTC012"
      ],
      "title": "RuleId",
      "type": "string"
    },
    "SecretSource": {
      "enum": [
        "heuristic",
        "config_override",
        "not_secret"
      ],
      "title": "SecretSource",
      "type": "string"
    },
    "SensitivityConfidence": {
      "enum": [
        "certain",
        "high",
        "none"
      ],
      "title": "SensitivityConfidence",
      "type": "string"
    },
    "SensitivityReason": {
      "enum": [
        "config_override",
        "token",
        "password",
        "secret",
        "private_key",
        "api_key",
        "credential",
        "secret_metadata",
        "no_match"
      ],
      "title": "SensitivityReason",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "error",
        "warning",
        "info"
      ],
      "title": "Severity",
      "type": "string"
    },
    "SourceLocation": {
      "additionalProperties": false,
      "properties": {
        "end_column": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Column"
        },
        "end_line": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Line"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "start_column": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Column"
        },
        "start_line": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Line"
        }
      },
      "required": [
        "path"
      ],
      "title": "SourceLocation",
      "type": "object"
    }
  },
  "$id": "urn:runtime-contract:analysis-result:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "completeness": {
      "$ref": "#/$defs/AnalysisCompleteness"
    },
    "diagnostics": {
      "default": [],
      "items": {
        "$ref": "#/$defs/AnalysisDiagnostic"
      },
      "title": "Diagnostics",
      "type": "array"
    },
    "observations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/FactObservation"
      },
      "title": "Observations",
      "type": "array"
    },
    "schema_id": {
      "const": "runtime-contract/analysis-result/v1",
      "default": "runtime-contract/analysis-result/v1",
      "title": "Schema Id",
      "type": "string"
    }
  },
  "required": [
    "completeness"
  ],
  "title": "runtime-contract analysis result version 1",
  "type": "object"
}
