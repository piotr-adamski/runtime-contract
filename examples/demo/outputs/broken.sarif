te-key content detected"}},{"defaultConfiguration":{"level":"warning"},"fullDescription":{"text":"A variable consumed by code is absent from the component's documenting source."},"help":{"text":"Declare the variable in the component's documentation source without adding a real secret value."},"id":"RTC004","name":"UNDOCUMENTED_VARIABLE","shortDescription":{"text":"Variable is not documented"}},{"defaultConfiguration":{"level":"warning"},"fullDescription":{"text":"A documented variable has no statically detected consumer in the selected component."},"help":{"text":"Remove the stale declaration or confirm and document the unsupported consumption pattern."},"id":"RTC005","name":"UNUSED_DECLARATION","shortDescription":{"text":"Declaration has no consumer"}},{"defaultConfiguration":{"level":"warning"},"fullDescription":{"text":"The variable name is computed dynamically and cannot be resolved safely by static analysis."},"help":{"text":"Use a statically named access or document the limitation; runtime-contract will not execute code or guess the name."},"id":"RTC006","name":"DYNAMIC_REFERENCE","shortDescription":{"text":"Variable reference is dynamic"}},{"defaultConfiguration":{"level":"warning"},"fullDescription":{"text":"Static sources describe incompatible fallback or default behavior for one variable."},"help":{"text":"Choose one intended default contract and align every static declaration and consumer."},"id":"RTC007","name":"CONFLICTING_DEFAULT","shortDescription":{"text":"Static defaults conflict"}},{"defaultConfiguration":{"level":"note"},"fullDescription":{"text":"An optional variable has no delivery for the selected target and phase."},"help":{"text":"No action is required when omission is intentional; otherwise add the matching delivery."},"id":"RTC008","name":"OPTIONAL_NOT_PROVIDED","shortDescription":{"text":"Optional variable not provided"}},{"defaultConfiguration":{"level":"error"},"fullDescription":{"text":"A bulk provider may deliver variables, but it cannot prove this required key for the selected target."},"help":{"text":"Add a statically verifiable key or an explicit valueless provides declaration for the target."},"id":"RTC009","name":"DELIVERY_UNVERIFIABLE","shortDescription":{"text":"Bulk delivery cannot be verified"}},{"defaultConfiguration":{"level":"error"},"fullDescription":{"text":"The variable is delivered only in a phase different from the consumer requirement."},"help":{"text":"Move or duplicate delivery into the required build or runtime phase."},"id":"RTC010","name":"PHASE_MISMATCH","shortDescription":{"text":"Delivery phase does not match"}},{"defaultConfiguration":{"level":"warning"},"fullDescription":{"text":"A dynamic Pydantic Settings source cannot be resolved without executing project code."},"help":{"text":"Expose a static field alias or prefix, or document the custom source as an intentional analysis limitation."},"id":"RTC011","name":"CUSTOM_SETTINGS_SOURCE","shortDescription":{"text":"Custom Settings source is dynamic"}},{"defaultConfiguration":{"level":"note"},"fullDescription":{"text":"The Kubernetes resource is outside the supported v0.1 workload and key-source set."},"help":{"text":"Use a supported plain manifest for analysis or assess the unsupported resource with its native tooling."},"id":"RTC012","name":"UNSUPPORTED_K8S_RESOURCE","shortDescription":{"text":"Kubernetes resource is unsupported"}}],"semanticVersion":"0.1.0-dev.0"}}}],"version":"2.1.0"}
