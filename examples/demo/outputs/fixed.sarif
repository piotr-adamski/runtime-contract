{"$schema":"https://json.schemastore.org/sarif-2.1.0.json","runs":[{"originalUriBaseIds":{"PROJECTROOT":{"uri":"./"}},"properties":{"policy":[],"schema_id":"runtime-contract/v1","selected_roots":["default"],"status":"complete","summary":{"analyzed":6,"candidate_kinds":{"compose":1,"dockerfile":1,"env_example":1,"javascript":1,"kubernetes":1,"python":1},"candidates":6,"complete_files":6,"config_keys":3,"consumers":3,"diagnostics":0,"failed_files":0,"findings":0,"flow_edges":24,"flow_nodes":18,"partial_files":0,"precedence_conflicts":3,"precedence_providers":9,"providers":9,"skipped":0,"skipped_reasons":{}}},"results":[],"tool":{"driver":{"name":"runtime-contract","rules":[{"defaultConfiguration":{"level":"error"},"fullDescription":{"text":"A required variable is not delivered to the selected target in the required phase."},"help":{"text":"Provide the variable to every selected target in the required phase, or explicitly make the requirement optional."},"id":"RTC001","name":"REQUIRED_NOT_PROVIDED","shortDescription":{"text":"Required variable not provided"}},{"defaultConfiguration":{"level":"error"},"fullDescription":{"text":"A non-placeholder literal for a sensitive variable can expose a secret in source configuration."},"help":{"text":"Replace the literal with an empty or approved placeholder, pass-through reference, or secret-backed delivery."},"id":"RTC002","name":"SECRET_LITERAL","shortDescription":{"text":"Secret has a literal value"}},{"defaultConfiguration":{"level":"error"},"fullDescription":{"text":"Private-key material in a scanned source is always sensitive regardless of the variable name."},"help":{"text":"Remove the private-key content from the repository and rotate the affected key outside runtime-contract."},"id":"RTC003","name":"PRIVATE_KEY_CONTENT","shortDescription":{"text":"Private-key content detected"}},{"defaultConfiguration":{"level":"warning"},"fullDescription":{"text":"A variable consumed by code is absent from the component's documenting source."},"help":{"text":"Declare the variable in the component's documentation source without adding a real secret value."},"id":"RTC004","name":"UNDOCUMENTED_VARIABLE","shortDescription":{"text":"Variable is not documented"}},{"defaultConfiguration":{"level":"warning"},"fullDescription":{"text":"A documented variable has no statically detected consumer in the selected component."},"help":{"text":"Remove the stale declaration or confirm and document the unsupported consumption pattern."},"id":"RTC005","name":"UNUSED_DECLARATION","shortDescription":{"text":"Declaration has no consumer"}},{"defaultConfiguration":{"level":"warning"},"fullDescription":{"text":"The variable name is computed dynamically and cannot be resolved safely by static analysis."},"help":{"text":"Use a statically named access or document the limitation; runtime-contract will not execute code or guess the name."},"id":"RTC006","name":"DYNAMIC_REFERENCE","shortDescription":{"text":"Variable reference is dynamic"}},{"defaultConfiguration":{"level":"warning"},"fullDescription":{"text":"Static sources describe incompatible fallback or default behavior for one variable."},"help":{"text":"Choose one intended default contract and align every static declaration and consumer."},"id":"RTC007","name":"CONFLICTING_DEFAULT","shortDescription":{"text":"Static defaults conflict"}},{"defaultConfiguration":{"level":"note"},"fullDescription":{"text":"An optional variable has no delivery for the selected target and phase."},"help":{"text":"No action is required when omission is intentional; otherwise add the matching delivery."},"id":"RTC008","name":"OPTIONAL_NOT_PROVIDED","shortDescription":{"text":"Optional variable not provided"}},{"defaultConfiguration":{"level":"error"},"fullDescription":{"text":"A bulk provider may deliver variables, but it cannot prove this required key for the selected target."},"help":{"text":"Add a statically verifiable key or an explicit valueless provides declaration for the target."},"id":"